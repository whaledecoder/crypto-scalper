# Copy to .env and fill in. All keys are optional for paper mode — in that case
# ARIA runs with TA-only fallback for the LLM and empty external feeds.
#
# After editing, load with:
#   set -a; source .env; set +a

# ============================================================================
# Exchange (Binance Futures)  — REQUIRED for live mode
# ============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ============================================================================
# LLM — Brain (the first decision maker)
# ============================================================================
# Default provider is OpenRouter (1 key, many models).
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Alternative providers — set the matching env var when [llm.provider] is changed.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# TOGETHER_API_KEY=
# GROQ_API_KEY=

# ============================================================================
# LLM — TraderManager (the second decision maker; off by default)
# ============================================================================
# Optional: use a *different* model for the manager than the brain.
# Falls back to the brain LLM key if unset.
MANAGER_API_KEY=

# ============================================================================
# News & sentiment feeds (all optional)
# ============================================================================
CRYPTOPANIC_API_KEY=
LUNARCRUSH_API_KEY=

# ============================================================================
# On-chain feeds (all optional)
# ============================================================================
GLASSNODE_API_KEY=
WHALE_ALERT_API_KEY=

# ============================================================================
# Telegram — alerts + (optional) command panel
# ============================================================================
# Outbound alerts go to TELEGRAM_CHAT_ID. To enable inbound commands
# (/status, /freeze, /flat etc.), also set [control] telegram_commands_enabled
# = true and add your numeric user id to [control] allowed_user_ids.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================================
# Misc
# ============================================================================
# Path to optional config overlay merged on top of config/default.toml.
ARIA_CONFIG_OVERLAY=config/paper.toml

# ----------------------------------------------------------------------------
# LLM model / provider overrides (no config edit required).
# Any non-empty value wins over config/default.toml + overlay.
# ----------------------------------------------------------------------------
# Brain LLM
#ARIA_LLM_PROVIDER=openrouter
#ARIA_LLM_MODEL=deepseek/deepseek-chat
#ARIA_LLM_API_BASE=https://openrouter.ai/api/v1/chat/completions
# TraderManager LLM (oversight) — can differ from Brain
#ARIA_MANAGER_PROVIDER=openrouter
#ARIA_MANAGER_MODEL=anthropic/claude-3.5-sonnet
#ARIA_MANAGER_API_BASE=https://openrouter.ai/api/v1/chat/completions

# Tracing filter. Examples:
#   info
#   info,crypto_scalper::agents::survival=debug
#   debug,hyper=warn,reqwest=warn
RUST_LOG=info
