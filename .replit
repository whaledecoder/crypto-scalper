modules = ["rust-stable"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 9184
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ARIA_CONFIG_OVERLAY=config/replit.toml ./target/debug/aria"
waitForPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "ARIA_CONFIG_OVERLAY=config/replit.toml ./target/release/aria"]
build = ["cargo", "build", "--release"]
